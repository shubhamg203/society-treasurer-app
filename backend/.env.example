# ============================================================
# Backend Environment Variables
# Copy this file to .env for local development:
#   cp .env.example .env
# On cloud platforms set these in the environment dashboard.
# ============================================================

# Flask secret key — generate a strong random value for production
# python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-strong-secret-key-here

# JWT secret key — generate separately from SECRET_KEY
JWT_SECRET_KEY=your-strong-jwt-secret-key-here

# Database URL
# Local dev:    sqlite:///society_treasurer.db
# Production:   postgresql://user:password@host:5432/dbname  (provided by Render/Railway)
DATABASE_URL=sqlite:///society_treasurer.db

# CORS origins — comma-separated list of allowed frontend URLs
# Local dev:    * (allow all)
# Production:   https://your-app.onrender.com,https://your-app.vercel.app
CORS_ORIGINS=*
